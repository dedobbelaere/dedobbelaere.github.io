---
import BaseHead from '../components/BaseHead.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface Props {
	title?: string;
	description?: string;
	headerTitle?: string;
	frontmatter?: any;
	publishDate?: Date;
	ogType?: 'website' | 'article';
}

const { title, description, headerTitle, frontmatter, publishDate, ogType } = Astro.props;

// For Markdown files using this layout, props are in 'frontmatter'
// For Astro components, they are in direct props
const finalTitle = title || frontmatter?.title || SITE_TITLE;
const finalDescription = description || frontmatter?.description || SITE_DESCRIPTION;
const finalHeaderTitle = headerTitle || frontmatter?.headerTitle || (frontmatter?.title) || (title && title !== "Home" ? title : null);
const finalPublishDate = publishDate || frontmatter?.date;

// Logic for Open Graph Type
const isBlog = Astro.url.pathname.startsWith('/blog/');
const finalOgType = ogType || (isBlog ? 'article' : 'website');

const displayHeader = finalHeaderTitle;
---

<!doctype html>
<html lang="en-us">
	<BaseHead title={finalTitle} description={finalDescription} publishDate={finalPublishDate} ogType={finalOgType} />
	<body class="theme-base-de">
		<Sidebar />
		<div class="content container">
			<div class="post">
				{displayHeader && <h1 class="post-title">{displayHeader}</h1>}
				<slot />
			</div>
		</div>
	</body>
</html>
