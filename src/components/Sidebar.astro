---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<div class="sidebar">
  <div class="container sidebar-sticky">
    <div class="sidebar-about">
      <div class="sidebar-header-mobile">
        <h1 class="sidebar-brand-mobile">
          <a href="/">Menu</a>
        </h1>
        <button id="sidebar-toggle" class="sidebar-toggle" aria-label="Toggle menu">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
      </div>
      <h1 class="sidebar-title-desktop">
        <a href="/">{SITE_TITLE}</a>
      </h1>
      <p class="lead sidebar-content-collapse">{SITE_DESCRIPTION}</p>
    </div>

    <nav class="sidebar-nav sidebar-content-collapse" id="sidebar-nav">
      <a class="sidebar-nav-item" href="/">Home</a>
      <a class="sidebar-nav-item" href="/blog">Blog</a>
      <a class="sidebar-nav-item" href="/cv">Curriculum Vitae</a>
      <a class="sidebar-nav-item" href="/bookRecs">Book Recommendations</a>
      <span class="sidebar-nav-item"><a href="mailto:contact@dedobb.xyz">Contact</a></span>
    </nav>

    <p class="sidebar-content-collapse">&copy; {new Date().getFullYear()}. All rights reserved.</p>
  </div>
</div>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  const sidebar = document.querySelector('.sidebar');
  
  toggle?.addEventListener('click', () => {
    sidebar?.classList.toggle('sidebar-expanded');
  });
</script>

<style>
  /* Mobile header styles */
  .sidebar-header-mobile {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .sidebar-brand-mobile {
    margin: 0;
    font-size: 1.5rem;
    font-family: "Inter", sans-serif;
  }

  .sidebar-toggle {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Desktop vs Mobile display */
  .sidebar-title-desktop {
    display: none;
  }

  .sidebar-content-collapse {
    display: none;
  }

  /* Expanded state for mobile */
  :global(.sidebar-expanded) .sidebar-content-collapse {
    display: block;
    margin-top: 1rem;
  }

  :global(.sidebar-expanded) .sidebar-title-desktop {
    display: block;
    margin-top: 1rem;
  }

  @media (min-width: 48em) {
    .sidebar-header-mobile {
      display: none;
    }
    .sidebar-title-desktop {
      display: block;
      margin-top: 0;
    }
    .sidebar-content-collapse {
      display: block;
    }
  }
</style>
